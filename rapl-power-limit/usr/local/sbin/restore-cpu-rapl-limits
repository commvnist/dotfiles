#!/usr/bin/env bash
set -euo pipefail

readonly PKG="${RAPL_POWER_LIMIT_PATH:-/sys/class/powercap/intel-rapl-mmio:0}"
readonly LOGGER_TAG="restore-cpu-rapl-limits"
readonly MONITOR_INTERVAL_SECONDS="${RAPL_POWER_LIMIT_MONITOR_INTERVAL_SECONDS:-1}"

readonly -a LIMIT_FILES=(
  "constraint_0_power_limit_uw"
  "constraint_1_power_limit_uw"
  "constraint_2_power_limit_uw"
)
readonly -a LIMIT_LABELS=(
  "PL1 long-term package"
  "PL2 short-term package"
  "PL4 peak package"
)
readonly -a LIMIT_VALUES_UW=(
  "55000000"
  "157000000"
  "234000000"
)
readonly -a LIMIT_VALUES_W=(
  "55"
  "157"
  "234"
)

DRIFT_DETAILS=()

# This host can expose both MSR-backed and MMIO-backed RAPL package limits.
# A stale firmware/platform state has been observed setting the MMIO long-term
# package limit to 25 W after resume, even while the MSR package limit remains
# high. The lower MMIO limit wins and pins CPU package power around 25 W.
#
# A long-running monitor mode is available for the second observed failure mode:
# firmware or another platform component can occasionally rewrite the same MMIO
# sysfs attributes after boot/resume. The monitor reads periodically and only
# writes when a value drifts, avoiding a blind 1 Hz write loop.

usage() {
  cat <<'USAGE'
Usage:
  restore-cpu-rapl-limits [--restore]
  restore-cpu-rapl-limits --check
  restore-cpu-rapl-limits --monitor

Modes:
  --restore  Write the expected MMIO RAPL package limits once. This is the default.
  --check    Exit 0 when limits match, 1 when they drift, 2 on operational error.
  --monitor  Restore once, then poll and restore only after detected drift.

Environment:
  RAPL_POWER_LIMIT_PATH
      sysfs package path to manage. Defaults to /sys/class/powercap/intel-rapl-mmio:0.
  RAPL_POWER_LIMIT_MONITOR_INTERVAL_SECONDS
      Positive integer polling interval for --monitor. Defaults to 1.
USAGE
}

log_notice() {
  logger -t "$LOGGER_TAG" -- "$*" 2>/dev/null || printf '%s\n' "$*" >&2
}

log_warning() {
  logger -p daemon.warning -t "$LOGGER_TAG" -- "$*" 2>/dev/null || printf 'warning: %s\n' "$*" >&2
}

log_error() {
  logger -p daemon.err -t "$LOGGER_TAG" -- "$*" 2>/dev/null || printf 'error: %s\n' "$*" >&2
}

target_summary() {
  printf 'PL1=%sW PL2=%sW PL4=%sW' \
    "${LIMIT_VALUES_W[0]}" \
    "${LIMIT_VALUES_W[1]}" \
    "${LIMIT_VALUES_W[2]}"
}

join_by() {
  local delimiter="$1"
  local item
  local result=""

  shift
  for item in "$@"; do
    if [[ -n "$result" ]]; then
      result+="$delimiter"
    fi
    result+="$item"
  done

  printf '%s' "$result"
}

is_positive_integer() {
  [[ "$1" =~ ^[1-9][0-9]*$ ]]
}

limit_path() {
  printf '%s/%s' "$PKG" "$1"
}

read_limit_uw() {
  local file="$1"
  local operation="$2"
  local path
  local value

  path="$(limit_path "$file")"
  if [[ ! -r "$path" ]]; then
    log_error "Cannot read MMIO RAPL limit during ${operation}: path=${path} cause=not_readable"
    return 1
  fi

  if ! IFS= read -r value < "$path"; then
    log_error "Cannot read MMIO RAPL limit during ${operation}: path=${path} cause=read_failed"
    return 1
  fi

  if [[ ! "$value" =~ ^[0-9]+$ ]]; then
    log_error "Invalid MMIO RAPL limit during ${operation}: path=${path} value=${value} cause=non_numeric"
    return 1
  fi

  printf '%s\n' "$value"
}

write_limit_uw() {
  local file="$1"
  local desired_uw="$2"
  local operation="$3"
  local path

  path="$(limit_path "$file")"
  if [[ ! -w "$path" ]]; then
    log_error "Cannot write MMIO RAPL limit during ${operation}: path=${path} desired_uw=${desired_uw} cause=not_writable"
    return 1
  fi

  if ! printf '%s\n' "$desired_uw" > "$path"; then
    log_error "Cannot write MMIO RAPL limit during ${operation}: path=${path} desired_uw=${desired_uw} cause=write_failed"
    return 1
  fi
}

check_limit_drift() {
  local operation="$1"
  local i
  local file
  local current_uw
  local desired_uw

  DRIFT_DETAILS=()

  if [[ ! -d "$PKG" ]]; then
    log_error "MMIO RAPL package path is unavailable during ${operation}: path=${PKG}"
    return 2
  fi

  for i in "${!LIMIT_FILES[@]}"; do
    file="${LIMIT_FILES[$i]}"
    desired_uw="${LIMIT_VALUES_UW[$i]}"
    current_uw="$(read_limit_uw "$file" "$operation")" || return 2

    if [[ "$current_uw" != "$desired_uw" ]]; then
      DRIFT_DETAILS+=("${LIMIT_LABELS[$i]}: current=${current_uw}uW target=${desired_uw}uW")
    fi
  done
}

restore_limits() {
  local operation="$1"
  local drift_summary="${2:-}"
  local i

  [ -d "$PKG" ] || return 0

  # The P16 Gen 2 currently reports 55 W as constraint_0_max_power_uw for the
  # long-term MMIO package limit. Do not exceed the exposed long-term maximum here;
  # transient boost remains covered by the short-term and peak limits below.
  for i in "${!LIMIT_FILES[@]}"; do
    write_limit_uw "${LIMIT_FILES[$i]}" "${LIMIT_VALUES_UW[$i]}" "$operation" || return 1
  done

  if [[ -n "$drift_summary" ]]; then
    log_notice "Corrected MMIO RAPL package limit drift: operation=${operation} drift=${drift_summary} target=$(target_summary)"
  else
    log_notice "Restored MMIO RAPL package limits: operation=${operation} target=$(target_summary)"
  fi
}

restore_if_drifted() {
  local operation="$1"
  local drift_summary

  check_limit_drift "$operation" || return $?

  if ((${#DRIFT_DETAILS[@]} == 0)); then
    return 0
  fi

  drift_summary="$(join_by '; ' "${DRIFT_DETAILS[@]}")"
  restore_limits "$operation" "$drift_summary"
}

check_once() {
  check_limit_drift "check" || return $?

  if ((${#DRIFT_DETAILS[@]} == 0)); then
    return 0
  fi

  printf '%s\n' "$(join_by '; ' "${DRIFT_DETAILS[@]}")" >&2
  return 1
}

monitor_limits() {
  local package_missing_logged=0

  if ! is_positive_integer "$MONITOR_INTERVAL_SECONDS"; then
    log_error "Invalid monitor interval: value=${MONITOR_INTERVAL_SECONDS} cause=not_positive_integer"
    return 2
  fi

  restore_limits "monitor initial restore"

  while true; do
    if [[ ! -d "$PKG" ]]; then
      if ((package_missing_logged == 0)); then
        log_warning "MMIO RAPL package path is unavailable; monitor will keep checking: path=${PKG}"
        package_missing_logged=1
      fi
      sleep "$MONITOR_INTERVAL_SECONDS"
      continue
    fi

    package_missing_logged=0
    restore_if_drifted "monitor drift check" || true
    sleep "$MONITOR_INTERVAL_SECONDS"
  done
}

main() {
  if (($# > 1)); then
    usage >&2
    return 2
  fi

  case "${1:---restore}" in
    --restore)
      restore_limits "manual restore"
      ;;
    --check)
      check_once
      ;;
    --monitor)
      monitor_limits
      ;;
    --help|-h)
      usage
      ;;
    *)
      usage >&2
      return 2
      ;;
  esac
}

main "$@"
